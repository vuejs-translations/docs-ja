{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress",
    "build": "vitepress build",
    "preview": "vitepress preview",
    "preinstall": "npx only-allow pnpm",
    "type": "vue-tsc --noEmit",
    "lint": "textlint --format pretty-error \"**/*.md\""
  },
  "dependencies": {
    "@vue/repl": "^4.7.1",
    "@vue/theme": "^2.4.0",
    "dynamics.js": "^1.1.5",
    "gsap": "^3.14.2",
    "vitepress": "^2.0.0-alpha.17",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@nexhome/yorkie": "^2.0.8",
    "@types/body-scroll-lock": "^3.1.2",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.2",
    "lint-staged": "^16.1.2",
    "oxc-minify": "^0.124.0",
    "textlint": "^15.2.0",
    "textlint-filter-rule-allowlist": "^4.0.0",
    "textlint-filter-rule-comments": "^1.2.2",
    "textlint-rule-preset-vuejs-jp": "github:vuejs-jp/textlint-rule-preset-vuejs-jp",
    "typescript": "^5.9.3",
    "vitepress-plugin-group-icons": "^1.7.3",
    "vue-tsc": "^3.2.6"
  },
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.md": "textlint --format pretty-error"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vitepress>vite": "npm:vite@8.0.7"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "vue-demi"
    ]
  }
}
